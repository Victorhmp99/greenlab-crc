PORT=3001

# Chave secreta compartilhada entre CRM e CRC
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRC_SECRET=troque_por_uma_chave_aleatoria_forte

# Origem permitida (URL do seu CRM em produção)
ALLOWED_ORIGIN=https://seu-crm.vercel.app

# Em produção, defina como 1 para forçar HTTPS
NODE_ENV=production
